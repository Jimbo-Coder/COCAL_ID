# Schedule definitions for thorn Cocal

if (CCTK_Equals(initial_data, "CocalRNS"))
{
   SCHEDULE coc2cac_rns IN HydroBase_Initial
   {
      LANG: FORTRAN
   }"Read Cocal RNS Initial Data into Cactus"
}

if (CCTK_Equals(initial_data, "CocalBNS"))
{
   SCHEDULE coc2cac_bns IN HydroBase_Initial
   {
      LANG: FORTRAN
   }"Read Cocal BNS Initial Data into Cactus"
}
