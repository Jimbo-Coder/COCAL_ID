#----------------------IllinoisGRMHD configuration----------------------
# Parameters of thorn Convert_to_HydroBase (implementing Convert_to_HydroBase)
IllinoisGRMHD::Convert_to_HydroBase_every = 16

#Spherical surface
SphericalSurface::nsurfaces = 4
SphericalSurface::maxntheta = 39
SphericalSurface::maxnphi = 76

SphericalSurface::ntheta      [0] = 39
SphericalSurface::nphi        [0] = 76
SphericalSurface::nghoststheta[0] = 2
SphericalSurface::nghostsphi  [0] = 2
SphericalSurface::set_spherical[0] = yes
SphericalSurface::name        [0] = "RNS"
SphericalSurface::origin_x     [0] = 0.0
SphericalSurface::radius      [0] = 5.0

SphericalSurface::ntheta      [1] = 39
SphericalSurface::nphi        [1] = 76
SphericalSurface::nghoststheta[1] = 2
SphericalSurface::nghostsphi  [1] = 2
SphericalSurface::set_spherical[1] = yes
SphericalSurface::name        [1] = "waveextract surface at 10"
SphericalSurface::origin_x     [1] = 0.0
SphericalSurface::radius      [1] = 10.0

SphericalSurface::ntheta      [2] = 39
SphericalSurface::nphi        [2] = 76
SphericalSurface::nghoststheta[2] = 2
SphericalSurface::nghostsphi  [2] = 2
SphericalSurface::set_spherical[2] = yes
SphericalSurface::radius      [2] = 12.0
SphericalSurface::name        [2] = "waveextract surface at 12"

SphericalSurface::ntheta      [3] = 39
SphericalSurface::nphi        [3] = 76
SphericalSurface::nghoststheta[3] = 2
SphericalSurface::nghostsphi  [3] = 2
SphericalSurface::set_spherical[3] = yes
SphericalSurface::radius      [3] = 15.0
SphericalSurface::name        [3] = "waveextract surface at 15"

#QuasiLocalMeasures

QuasiLocalMeasures::num_surfaces   = 4
QuasiLocalMeasures::spatial_order  = 4
QuasiLocalMeasures::interpolator = "Lagrange polynomial interpolation"
QuasiLocalMeasures::interpolator_options = "order=4"

QuasiLocalMeasures::surface_name[0] = "RNS"
QuasiLocalMeasures::surface_index[0] = 0

QuasiLocalMeasures::surface_name[1] = "waveextract surface at 10"
QuasiLocalMeasures::surface_index[1] = 1

QuasiLocalMeasures::surface_name[2] = "waveextract surface at 12"
QuasiLocalMeasures::surface_index[2] = 2

QuasiLocalMeasures::surface_name[3] = "waveextract surface at 15"
QuasiLocalMeasures::surface_index[3] = 3


# Volume Integrals 
VolumeIntegrals_GRMHD::NumIntegrals = 2
VolumeIntegrals_GRMHD::VolIntegral_out_every = $out_every
VolumeIntegrals_GRMHD::enable_file_output = 1
VolumeIntegrals_GRMHD::outVolIntegral_dir = "./volume_integration"
VolumeIntegrals_GRMHD::verbose = 1
# The AMR centre will only track the first referenced integration quantities that track said centre.
#   Thus, centeroflapse output will not feed back into the AMR centre positions.

VolumeIntegrals_GRMHD::Integration_quantity_keyword[1] = "centerofmass"

VolumeIntegrals_GRMHD::Integration_quantity_keyword[2] = "restmass"


VolumeIntegrals_GRMHD::volintegral_inside_sphere__radius            [1] =  7.0





VolumeIntegrals_vacuum::HamiltonianVarString                   = "Baikal::HGF"
VolumeIntegrals_vacuum::Momentum0VarString                     = "Baikal::MU0GF"
VolumeIntegrals_vacuum::Momentum1VarString                     = "Baikal::MU1GF"
VolumeIntegrals_vacuum::Momentum2VarString                     = "Baikal::MU2GF"
VolumeIntegrals_vacuum::NumIntegrals                           = 6
VolumeIntegrals_vacuum::VolIntegral_out_every                  = $out_every
VolumeIntegrals_vacuum::enable_file_output                     = 1
VolumeIntegrals_vacuum::outVolIntegral_dir                     = "./volume_integration"
VolumeIntegrals_vacuum::verbose                                = 1

VolumeIntegrals_vacuum::Integration_quantity_keyword[1]       = "ADM_Mass"
VolumeIntegrals_vacuum::Integration_quantity_keyword[2]       = "ADM_Angular_Momentum"
VolumeIntegrals_vacuum::Integration_quantity_keyword[3]       = "ADM_Angular_Momentum"
VolumeIntegrals_vacuum::Integration_quantity_keyword[4]       = "ADM_Angular_Momentum"
VolumeIntegrals_vacuum::Integration_quantity_keyword[5]       = "ADM_Angular_Momentum"
VolumeIntegrals_vacuum::Integration_quantity_keyword[6]        = "H_M_CnstraintsL2"

VolumeIntegrals_vacuum::volintegral_inside_sphere__radius[3] = 15.
VolumeIntegrals_vacuum::volintegral_inside_sphere__radius[4] = 20.
VolumeIntegrals_vacuum::volintegral_inside_sphere__radius[5] = 21.

# I/O

# Use (create if necessary) an output directory named like the
# parameter file (minus the .par)
IO::out_dir             = ${parfile}

# Write one file overall per output (variable/group)
# In production runs, comment this or set to "proc" to get one file
# per MPI process
IO::out_mode            = "onefile"

# Some screen output
IOBasic::outInfo_every = 64
IOBasic::outInfo_vars  = "Carpet::physical_time_per_hour HydroBase::rho{reductions='maximum'} Baikal::HGF{reductions='maximum'}"

#---------GRHayLib---------
GRHayLib::EOS_type                    = "Hybrid"
#GRHayLib::EOS_tablepath               = "Hempel_SFHoEOS_rho222_temp180_ye60_version_1.1_20120817_adjusted.h5"

GRHayLib::neos                        = 4
GRHayLib::gamma_th                    = 1.6666666666666667
GRHayLib::k_ppoly0                    = 8.94713335e-2
GRHayLib::gamma_ppoly_in              = [1.35692, 4.07, 2.411, 1.89]
GRHayLib::rho_ppoly_in                = [3.15519e-04, 8.11939e-04, 1.62003e-03]


GRHayLib::evolve_temperature          = no
GRHayLib::con2prim_routine            = "Palenzuela1D"
GRhayLib::con2prim_backup_routines[0] = "Newman1D"
GRHayLib::rho_b_atm                   = 1e-12
GRHayLib::rho_b_min                   = 1e-12
GRHayLib::rho_b_max                   = 0.004
GRHayLib::Y_e_atm                     = 0.5
GRHayLib::Y_e_max                     = 0.5
GRHayLib::T_atm                       = 1e-2
GRHayLib::T_min                       = 1e-2
GRHayLib::T_max                       = 90
GRHayLib::Psi6threshold               = 60
GRHayLib::Lorenz_damping_factor       = 0.1
GRHayLib::calc_primitive_guess        = yes

#---------GRHayLID---------
#GRHayLID::impose_beta_equilibrium = "yes"
#GRHayLID::beq_temperature         = GRHayLib::T_atm

# Scalar output
IOScalar::outScalar_every    = $out_every
IOScalar::one_file_per_group = "yes"
IOScalar::outScalar_reductions = "norm1 norm2 norm_inf sum maximum minimum"
IOScalar::outScalar_vars     = "
 HydroBase::rho
 HydroBase::press
 HydroBase::vel
 HydroBase::eps
 HydroBase::Bvec
 ADMBase::lapse
 ADMBase::shift
 Baikal::HGF{reductions='norm1 norm2 maximum minimum norm_inf sum_abs_squared'}
 Baikal::MU0GF{reductions='norm1 norm2 maximum minimum norm_inf sum_abs_squared'}
 Carpet::timing{reductions='average'}
 #VolumeIntegrals_vacuum::MADM_GFtest
"
CarpetIOHDF5::checkpoint                  = yes
IOUtil::checkpoint_dir                  = $parfile
IOUtil::checkpoint_ID                   = yes
IOUtil::checkpoint_on_terminate         = yes
IOUtil::recover     = "autoprobe"
IOUtil::recover_dir = $parfile

#out 0d vars

CarpetIOASCII::out0D_every     = $out_every # every_coarse
CarpetIOASCII::out0D_vars      = "
 Carpet::timing
 #AngularMom::Jmat
 #Angularmom::surfaceintegrals
 #AngularMom::Jadm
 QuasiLocalMeasures::qlm_scalars
 QuasiLocalMeasures::qlm_multipole_moments
 QuasiLocalMeasures::qlm_grid_real
 SphericalSurface::sf_active

 SphericalSurface::sf_valid
 SphericalSurface::sf_info
 SphericalSurface::sf_radius
 SphericalSurface::sf_origin
 SphericalSurface::sf_coordinate_descriptors
"

# 1D ASCII output. Disable for production runs!
CarpetIOASCII::out1D_every        = $out_every
CarpetIOASCII::one_file_per_group = yes
CarpetIOASCII::output_symmetry_points = no
CarpetIOASCII::out1D_vars         = "
 HydroBase::rho
 HydroBase::vel
 HydroBase::press
 HydroBase::eps
 HydroBase::Bvec
 ADMBase::lapse
 ADMBase::metric
 ADMBase::curv
 Baikal::HGF
 Baikal::MU0GF
 #VolumeIntegrals_vacuum::MADM_GFtest
"

# 2D HDF5 output
CarpetIOHDF5::output_buffer_points = "no"

CarpetIOHDF5::out2D_every = $out_every
CarpetIOHDF5::out2D_vars = "
 HydroBase::rho
 HydroBase::vel
 HydroBase::press
 HydroBase::eps
 HydroBase::Bvec
 ADMBase::lapse
 ADMBase::shift
 ADMBase::metric
 Baikal::HGF
 Baikal::MU0GF
 #VolumeIntegrals_vacuum::MADM_GFtest
 "

