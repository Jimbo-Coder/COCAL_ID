# GRHayLib (ILGRMHD) + Baikal 1Layer (magnetized)
$out_every=64
ActiveThorns = "
  ADMBase
  ADMCoupling
  ADMMacros
  AEILocalInterp
  #AngularMom
  Baikal
  Boundary
  Carpet
  CarpetInterp
  CarpetIOASCII
  CarpetIOBasic
  CarpetIOHDF5
  CarpetIOScalar
  CarpetLib
  CarpetReduce
  CarpetRegrid2
  CarpetSlab
  CartGrid3D
  CCE_Export
  CoordBase
  CoordGauge
  COCAL_ID
  CycleClock
  EOS_Omni
  HydroBase
  InitBase
  IOUtil
  #LocalInterp
  LocalReduce
  LoopControl
  #LORENE
  #Meudon_Bin_NS
  MoL
  Multipole
  NewRad
  NaNChecker
  QuasiLocalMeasures
  Slab
  smallbPoynET
  SpaceMask
  SphericalSurface
  StaticConformal
  SummationByParts
  SymBase
  SystemTopology
  SystemStatistics
  TerminationTrigger
  TGRtensor
  Time
  Timers
  TimerReport
  TmunuBase
  Trigger
  Vectors
  WeylScal4 
  VolumeIntegrals_GRMHD
  VolumeIntegrals_vacuum

  IllinoisGRMHD
  GRHayLib
  #GRHayLID

"


# Finalize
Cactus::terminate           = "time"
Cactus::cctk_final_time     = 12120 #  divide by ~203 to get ms





# Termination Trigger

TerminationTrigger::max_walltime = @WALLTIME_HOURS@          # hours
TerminationTrigger::on_remaining_walltime = 15  # minutes
TerminationTrigger::check_file_every = 512
TerminationTrigger::termination_file = "TerminationTrigger.txt"
TerminationTrigger::termination_from_file   = "yes"
TerminationTrigger::create_termination_file = "yes"

TimerReport::out_every    = 4096
TimerReport::out_filename = "TimerReport"
TimerReport::output_all_timers          = "yes"
TimerReport::output_all_timers_together = "yes"
TimerReport::output_all_timers_readable = "yes"
TimerReport::n_top_timers               = 40


# grid parameters
Carpet::domain_from_coordbase = "yes"
CartGrid3D::type         = "coordbase"
CartGrid3D::domain       = "full"
CartGrid3D::avoid_origin = "no"

#----------------------CarpetInterp configuration-----------------------
CarpetInterp::check_tree_search = "no"
CarpetInterp::tree_search       = "yes"

CoordBase::xmax = 16.0 #240.0
CoordBase::ymax = CoordBase::xmax
CoordBase::zmax = CoordBase::xmax
CoordBase::xmin = -CoordBase::xmax
CoordBase::ymin = -CoordBase::xmax
CoordBase::zmin = -CoordBase::xmax  #-240.0
# Change these parameters to change resolution. The ?max settings above
# have to be multiples of these. 'dx' is the size of one cell in x-direction.
# Making this smaller means using higher resolution, because more points will
# be used to cover the same space.
CoordBase::dx   =  0.25 # exponent is number of ref levels -1, gives that value at the most refined level.
CoordBase::dy   =  CoordBase::dx 
CoordBase::dz   = CoordBase::dx 

CarpetRegrid2::regrid_every =   0
CarpetRegrid2::num_centres  =   1
CarpetRegrid2::num_levels_1 = 1
#CarpetRegrid2::radius_1[1]  = 480.0
#CarpetRegrid2::radius_1[1]  = 240.0
#CarpetRegrid2::radius_1[1]  = 120.0
#CarpetRegrid2::radius_1[2]  = 60.0
#CarpetRegrid2::radius_1[3]  = 30.0
#CarpetRegrid2::radius_1[4]  = 15.0





CoordBase::boundary_size_x_lower        = 3
CoordBase::boundary_size_y_lower        = 3
CoordBase::boundary_size_z_lower        = 3
CoordBase::boundary_size_x_upper        = 3
CoordBase::boundary_size_y_upper        = 3
CoordBase::boundary_size_z_upper        = 3
CoordBase::boundary_shiftout_x_lower    = 1
CoordBase::boundary_shiftout_y_lower    = 1
CoordBase::boundary_shiftout_z_lower    = 1
CoordBase::boundary_shiftout_x_upper    = 0
CoordBase::boundary_shiftout_y_upper    = 0
CoordBase::boundary_shiftout_z_upper    = 0

#CCE_Export
CCE_Export::nradii       = 1
CCE_Export::radius[0]    = 10.00
#CCE_Export::radius[1]    = 20.00
#CCE_Export::radius[2]    = 100.00
#CCE_Export::radius[3]    = 200.00
#CCE_Export::radius[4]    = 220.00
CCE_Export::out_every    = 64


#ReflectionSymmetry::reflection_x = "no"
#ReflectionSymmetry::reflection_y = "no"
#ReflectionSymmetry::reflection_z = "no"
#ReflectionSymmetry::avoid_origin_x = "no"
#ReflectionSymmetry::avoid_origin_y = "no"
#ReflectionSymmetry::avoid_origin_z = "no"

# storage and coupling
TmunuBase::stress_energy_storage = yes
TmunuBase::stress_energy_at_RHS  = yes
TmunuBase::timelevels            =  3
TmunuBase::prolongation_type     = none


HydroBase::timelevels            = 3

ADMMacros::spatial_order = 4

ADMBase::metric_type     = "physical"
SpaceMask::use_mask      = "yes"

Carpet::enable_all_storage       = no
Carpet::use_buffer_zones         = "yes"

Carpet::poison_new_timelevels    = "yes"
Carpet::check_for_poison         = "no"

Carpet::init_3_timelevels        = no
Carpet::init_fill_timelevels     = "yes"

CarpetLib::poison_new_memory = "yes"
CarpetLib::poison_value      = 114
CarpetLib::support_staggered_operators = "yes"

Carpet::output_timers_every = 64

# system specific Carpet paramters
Carpet::max_refinement_levels    = 10
driver::ghost_size               = 3
Carpet::prolongation_order_space = 5
Carpet::prolongation_order_time  = 2

# Time integration
time::dtfac = 0.4
time::timestep_method = "courant_static"

MoL::ODE_Method             = "rk4"
MoL::MoL_Intermediate_Steps = 4
MoL::MoL_Num_Scratch_Levels = 1

#----------------------Multipole configuration--------------------------
Multipole::out_dir			 = "./data/Multipole"
Multipole::l_max                         = 4
Multipole::nphi                          = 240
Multipole::nradii                        = 1
Multipole::ntheta                        = 120
Multipole::out_every                     = 64
Multipole::output_ascii                  = yes
Multipole::output_hdf5                   = yes
Multipole::radius[0]                     = 10.0#220.00

Multipole::variables                     = "WeylScal4::Psi4r{sw=-2 cmplx='WeylScal4::Psi4i' name='psi4'}"

# check all physical variables for NaNs
#  This can save you computing time, so it's not a bad idea to do this
#  once in a whioe.

NaNChecker::check_every = 32
NaNChecker::action_if_found = "terminate" #"terminate", "just warn", "abort"
NaNChecker::check_vars = "ADMBase::metric ADMBase::lapse ADMBase::shift HydroBase::rho HydroBase::eps HydroBase::press HydroBase::vel HydroBase::Bvec"

# Hydro paramters



#HydroBase::evolution_method      = "GRHydro"
#HydroBase::bvec_evolution_method = "GRHydro"




# Curvature evolution parameters


ADMBase::evolution_method        = "Baikal"
ADMBase::lapse_evolution_method  = "Baikal"
ADMBase::shift_evolution_method  = "Baikal"
ADMBase::dtlapse_evolution_method= "Baikal"
ADMBase::dtshift_evolution_method= "Baikal"

#----------------------Baikal configuration-----------------------------
Baikal::diss_strength = 0.2
Baikal::eta           = 1.0/2.8    # M_ADM (from LORENE)



# init parameters
InitBase::initial_data_setup_method = "init_some_levels"


#Initial data
#WL: /anvil/projects/x-mca99s008/coc2cac_IDs/rns/rnsH2_ALF2_WL_BBB_sol12
#CF: /anvil/projects/x-mca99s008/coc2cac_IDs/rns/rnsH3_ALF2_CF_M1.4_jbxz_sol28
#MWL: /anvil/projects/x-mca99s008/coc2cac_IDs/rns/work_area_RNS_M1.25_df42_SE3_l60_th384_Mpa1.1_LCm0.6
#COCAL_ID::PathToID = "/anvil/projects/x-mca99s008/coc2cac_IDs/rns/rnsH2_ALF2_WL_BBB_sol12"
COCAL_ID::COCAL_ID_PathToID = "/home/nickd/cocal_IDs/rns/sol_12"
COCAL_ID::COCAL_ID_readpot = "False"

#Type of ID
# [RNS_WL, RNS_CF, MRNS_WL]
COCAL_ID::COCAL_ID_rnstype = "RNS_WL"

COCAL_ID::COCAL_ID_readformat = "20.12"


# Use TOV as initial data
#ActiveThorns = "TOVSolver"
ADMBase::initial_data            = "CocalRNS"
ADMBase::initial_lapse           = "Cocal"
ADMBase::initial_shift           = "Cocal"
HydroBase::initial_hydro         = "Cocal"
HydroBase::initial_Y_e         = "none"
HydroBase::initial_temperature = "none"
HydroBase::initial_entropy     = "none"
HydroBase::initial_Avec        = "zero"
HydroBase::initial_Aphi        = "zero"
HydroBase::initial_Bvec          = "zero"
ADMBase::initial_dtlapse         = "zero"
ADMBase::initial_dtshift         = "zero"

ADMBase::metric_timelevels        = 3
ADMBase::lapse_timelevels         = 3
ADMBase::shift_timelevels         = 3


# Parameters for initial star
#TOVSolver::TOV_Rho_Central[0] = 1.28e-3
#TOVSolver::TOV_Gamma          = 2
#TOVSolver::TOV_K              = 100

# Set equation of state for evolution
#EOS_Omni::poly_gamma                   = 2.0
#EOS_Omni::poly_k                       = 123.6
